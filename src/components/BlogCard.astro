---
import { formatDriveUrl } from '../lib/utils';

interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  feature_image: string;
}

const { title, description, date, slug, feature_image } = Astro.props;
const displayImg = formatDriveUrl(feature_image);

// Format date to 'd MMMM yyyy' (Indonesian)
const d = new Date(date);
let formattedDate = date; 

if (!isNaN(d.getTime())) {
  formattedDate = new Intl.DateTimeFormat('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(d);
}
---

<article class="bg-gray-900 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-800 flex items-stretch h-full w-full">
  <div class="p-6 flex flex-col flex-grow">
    <time class="text-xs text-blue-400 font-semibold mb-2 block">{formattedDate}</time>
    <h3 class="font-bold text-white mb-3 line-clamp-2 leading-tight text-xl uppercase">
      <a href={`/blog/${slug}`} class="hover:text-blue-300 transition-colors">
        {title}
      </a>
    </h3>
    <p class="text-sm text-gray-400 line-clamp-3 mb-4 flex-grow">
      {description}
    </p>
    
    <a 
      href={`/blog/${slug}`}
      class="text-blue-400 font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all self-start"
    >
      Baca Selengkapnya
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
  
  <div class="w-1/3 min-w-[200px] bg-gray-800 overflow-hidden">
    <img 
      src={displayImg || '/favicon.svg'} 
      alt={title}
      class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
      onerror="this.src='/favicon.svg'"
    />
  </div>
</article>
