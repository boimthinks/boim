---
import { formatDriveUrl } from '../lib/utils';

interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  feature_image: string;
}

const { title, description, date, slug, feature_image } = Astro.props;
const displayImg = formatDriveUrl(feature_image);

// Format date to 'd MMMM yyyy' (Indonesian)
// Parse DD/MM/YYYY format correctly
const parseDate = (dateStr: string) => {
  const [datePart, timePart] = dateStr.split(' ');
  const [day, month, year] = datePart.split('/');
  return new Date(`${year}-${month}-${day}T${timePart}`);
};

const d = parseDate(date);
let formattedDate = date;

if (!isNaN(d.getTime())) {
  formattedDate = new Intl.DateTimeFormat('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(d);
}
---

<article class="overflow-hidden shadow-sm hover:shadow-md transition-shadow flex items-stretch h-full w-full gap-6">
  <div class="flex flex-col flex-grow">
    <time class="text-xs text-gray-600 font-semibold mb-2 block">{formattedDate}</time>
    <h3 class="font-bold text-white mb-3 line-clamp-2 leading-tight text-xl uppercase">
      <a href={`/blog/${slug}`} class="hover:text-blue-300 transition-colors">
        {title}
      </a>
    </h3>
    <p class="text-sm text-gray-400 line-clamp-3 mb-4 flex-grow">
      {description}
    </p>


  </div>

  <div class="w-1/3 min-w-[200px] bg-gray-800 rounded-xl overflow-hidden max-md:hidden">
    <img
      src={displayImg || '/icon.svg'}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-300 hover:scale-105 filter grayscale"
      onerror="this.src='/no_image.webp'"
      referrerpolicy="no-referrer"
    />
  </div>
</article>
