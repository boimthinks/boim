---
interface Props {
  title: string;
  description: string;
  category: string;
  url: string;
  preview_image: string;
}

const { title, description, category, url, preview_image } = Astro.props;
---

<article class="group reveal cursor-pointer portfolio-trigger" 
  data-title={title} 
  data-description={description} 
  data-category={category} 
  data-url={url} 
  data-image={preview_image}>
  <div class="block no-underline">
    <div class="relative overflow-hidden rounded-xl mb-4 bg-surface-secondary">
      <div class="pt-[57.5%]">
        {preview_image ? (
          <img
            src={preview_image}
            alt={title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out-expo group-hover:scale-105"
          />
        ) : (
          <div class="absolute inset-0 bg-gradient-to-br from-teal/30 to-green-fern/30">
            <svg class="w-full h-full opacity-20 text-content-muted" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
              <defs>
                <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                  <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.5"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid)" />
            </svg>
          </div>
        )}
      </div>
    </div>
    <span class="inline-block text-xs font-semibold uppercase tracking-wider text-green-electric mb-2">{category}</span>
    <h3 class="font-bold text-2xl mt-1 mb-2 line-clamp-2 leading-tight transition-colors duration-300 group-hover:text-green-electric">
      {title}
    </h3>
    <p class="text-lg text-content-secondary line-clamp-2">{description}</p>
  </div>
</article>
