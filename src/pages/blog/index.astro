---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getBlogPosts } from '../../lib/api';
import matter from 'gray-matter';

const posts = await getBlogPosts();
const processedPosts = posts.map((post: any) => {
  try {
    const { data } = matter(post.content);
    return {
      title: data.title_short,
      description: data.description,
      date: data.published_at,
      slug: data.slug,
      feature_image: data.feature_image,
      tags: data.tags ? data.tags.split(',').map((t: string) => t.trim()).filter(Boolean) : [],
    };
  } catch (e) {
    console.error("Error parsing frontmatter:", e);
    return null;
  }
}).filter(Boolean).sort((a: any, b: any) => {
  return ((dateStr: string) => {
const [datePart, timePart] = dateStr.split(' ');
const [day, month, year] = datePart.split('/');
return new Date(`${year}-${month}-${day}T${timePart}`);
})(b.date).getTime() - ((dateStr: string) => {
const [datePart, timePart] = dateStr.split(' ');
const [day, month, year] = datePart.split('/');
return new Date(`${year}-${month}-${day}T${timePart}`);
})(a.date).getTime();
});

const tagCounts: Record<string, number> = {};
for (const post of processedPosts) {
  for (const tag of post.tags) {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  }
}
const sortedTags = Object.entries(tagCounts).sort(([, a], [, b]) => b - a);
const topTags = sortedTags.slice(0, 5).map(([tag]) => tag);
---

<Layout title="boim.thinks() | Archive">
	<main class="max-w-4xl mx-auto p-6">
		<h1 class="text-2xl font-bold mb-8">All Posts</h1>

		<div id="tag-filters" class="flex gap-2 mb-10 overflow-x-auto no-scrollbar">
			<button class="tag-btn active shrink-0 px-2 py-1 text-xs uppercase rounded-full border transition-colors cursor-pointer bg-blue-600 text-white border-blue-600 hover:bg-blue-700" data-tag="all">
			All
			</button>
			{topTags.map((tag) => (
				<button class="tag-btn shrink-0 px-2 py-1 text-xs uppercase rounded-full border transition-colors cursor-pointer bg-gray-800 text-gray-300 border-gray-700 hover:bg-gray-700 hover:text-white" data-tag={tag}>
					{tag}
					<span class="ml-1.5 text-xs opacity-70">({tagCounts[tag]})</span>
				</button>
			))}
		</div>

		<div id="post-list" class="grid gap-10">
			{processedPosts.map((post: any) => (
				<article class="post-item" data-tags={post.tags.join(',')}>
					<BlogCard {...post} />
				</article>
			))}
		</div>
	</main>
</Layout>

<script>
	const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
	const posts = document.querySelectorAll<HTMLElement>('.post-item');

	filterBtns.forEach((btn) => {
		btn.addEventListener('click', () => {
			const tag = btn.dataset.tag ?? 'all';

			filterBtns.forEach((b) => {
				b.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
				b.classList.add('bg-gray-800', 'text-gray-300', 'border-gray-700');
			});
			btn.classList.remove('bg-gray-800', 'text-gray-300', 'border-gray-700');
			btn.classList.add('bg-blue-600', 'text-white', 'border-blue-600');

			posts.forEach((post) => {
				if (tag === 'all') {
					post.style.display = '';
				} else {
					const postTags = post.dataset.tags?.split(',') || [];
					post.style.display = postTags.includes(tag) ? '' : 'none';
				}
			});
		});
	});
</script>

<style>
	.no-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}
</style>
