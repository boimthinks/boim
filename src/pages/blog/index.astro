---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getBlogPosts } from '../../lib/api';
import matter from 'gray-matter';

const posts = await getBlogPosts();
const processedPosts = posts.map((post: any) => {
  try {
    const { data } = matter(post.content);
    return {
      title: data.title_short,
      description: data.description,
      date: data.published_at,
      slug: data.slug,
      feature_image: data.feature_image,
      tags: data.tags ? data.tags.split(',').map((t: string) => t.trim()).filter(Boolean) : [],
    };
  } catch (e) {
    console.error("Error parsing frontmatter:", e);
    return null;
  }
}).filter((p): p is any => p !== null).sort((a: any, b: any) => {
  const parseDate = (dateStr: string) => {
    if (!dateStr) return new Date(0);
    const [datePart, timePart] = dateStr.split(' ');
    if (!datePart) return new Date(0);
    const [day, month, year] = datePart.split('/');
    return new Date(`${year || '1970'}-${month || '01'}-${day || '01'}T${timePart || '00:00:00'}`);
  };
  return parseDate(b.date).getTime() - parseDate(a.date).getTime();
});

const tagCounts: Record<string, number> = {};
for (const post of processedPosts) {
  for (const tag of post.tags) {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  }
}
const sortedTags = Object.entries(tagCounts).sort(([, a], [, b]) => b - a);
const topTags = sortedTags.slice(0, 5).map(([tag]) => tag);
---

<Layout title="boim.thinks() | Archive">
  <section class="px-6 s:px-16 d:px-100 pt-12 s:pt-10 pb-12 s:pb-16">
    <div class="max-w-[90rem] mx-auto">
      <p class="text-content-muted text-sm font-medium mb-4 reveal">Archive</p>
      <h1 class="text-3xl s:text-4xl d:text-5xl font-black leading-[1.1] reveal" style="transition-delay: 0.1s">All Posts</h1>
    </div>
  </section>

  <section class="px-6 s:px-16 d:px-100 pb-12 s:pb-16">
    <div class="max-w-[90rem] mx-auto">
      <div id="tag-filters" class="flex gap-2 mb-10 overflow-x-auto no-scrollbar">
        <button class="tag-btn active shrink-0 px-4 py-1.5 text-xs font-medium rounded-full border transition-all duration-300 cursor-pointer bg-green-electric text-surface border-green-electric hover:bg-green-electric/90" data-tag="all">
          All
        </button>
        {topTags.map((tag) => (
          <button class="tag-btn shrink-0 px-4 py-1.5 text-xs font-medium rounded-full border transition-all duration-300 cursor-pointer bg-transparent text-content-secondary border-white/10 hover:border-green-electric hover:text-green-electric" data-tag={tag}>
            {tag}
            <span class="ml-1 text-xs opacity-60">({tagCounts[tag]})</span>
          </button>
        ))}
      </div>

      <div id="post-list" class="grid grid-cols-1 s:grid-cols-2 pb-24 gap-x-15 gap-y-15">
        {processedPosts.map((post: any) => (
          <article class="post-item" data-tags={post.tags.join(',')}>
            <BlogCard {...post} />
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const posts = document.querySelectorAll<HTMLElement>('.post-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'all';
      filterBtns.forEach((b) => {
        b.classList.remove('bg-green-electric', 'text-surface', 'border-green-electric');
        b.classList.add('bg-transparent', 'text-content-secondary', 'border-white/10');
      });
      btn.classList.remove('bg-transparent', 'text-content-secondary', 'border-white/10');
      btn.classList.add('bg-green-electric', 'text-surface', 'border-green-electric');

      posts.forEach((post) => {
        if (tag === 'all') {
          post.style.display = '';
        } else {
          const postTags = post.dataset.tags?.split(',') || [];
          post.style.display = postTags.includes(tag) ? '' : 'none';
        }
      });
    });
  });
</script>

<style>
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
