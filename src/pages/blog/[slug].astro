---
import Layout from '../../layouts/Layout.astro';
import { getBlogPosts } from '../../lib/api';
import { marked } from 'marked';
import { formatDriveUrl } from '../../lib/utils';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post: any) => {
    try {
      const { data } = matter(post.content);
      return {
        params: { slug: data.slug },
        props: { post },
      };
    } catch (e) {
      console.error("Error generating path:", e);
      return null;
    }
  }).filter(Boolean);
}

const { post } = Astro.props as { post: any };
let data: any = {};
let htmlContent = "";
let parsed: any = null;

// Parse DD/MM/YYYY format correctly
const parseIndonesianDate = (dateStr: string) => {
  if (!dateStr) return null;
  try {
    const [datePart, timePart] = dateStr.split(' ');
    const [day, month, year] = datePart.split('/');
    return new Date(`${year}-${month}-${day}T${timePart}`);
  } catch (e) {
    console.error("Error parsing date:", e);
    return new Date(dateStr); // fallback to default parsing
  }
};

try {
  parsed = matter(post.content);
  data = parsed.data;
  const renderer = new marked.Renderer();
  renderer.link = ({ href, title, text }) => {
    const titleAttr = title ? ` title="${title}"` : '';
    return `<a href="${href}" target="_blank" rel="noopener noreferrer"${titleAttr}>${text}</a>`;
  };
  renderer.image = ({ href, title, text }) => {
    const src = formatDriveUrl(href);
    const alt = text || title || '';
    const titleAttr = title ? ` title="${title}"` : '';
    return `<img src="${src}" alt="${alt}"${titleAttr} class="w-full h-auto rounded-lg my-4" referrerpolicy="no-referrer" onerror="this.src='/no_image.webp'" />`;
  };
  marked.use({ renderer });
  htmlContent = await marked.parse(parsed.content);
} catch (e) {
  console.error("Error parsing content:", e);
}

const imageUrl = formatDriveUrl(data.feature_image);

let formattedDate = data.published_at;
try {
  const d = parseIndonesianDate(data.published_at);
  if (d && !isNaN(d.getTime())) {
    formattedDate = new Intl.DateTimeFormat('id-ID', {
      day: 'numeric',
      month: 'long',
      year: 'numeric'
    }).format(d);
  }
} catch (e) {
  console.error("Error formatting date:", e);
  formattedDate = data.published_at || "Tanggal tidak tersedia";
}

// Create Schema.org structured data
const formatDateForSchema = (dateStr: string) => {
  try {
    const parsedDate = parseIndonesianDate(dateStr);
    return parsedDate ? parsedDate.toISOString() : new Date().toISOString();
  } catch (e) {
    console.error("Error formatting date for schema:", e);
    return new Date().toISOString();
  }
};

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": data.title_seo || data.title_short,
  "description": data.description,
  "datePublished": data.published_at ? formatDateForSchema(data.published_at) : new Date().toISOString(),
  "dateModified": data.updated_at ? formatDateForSchema(data.updated_at) : (data.published_at ? formatDateForSchema(data.published_at) : new Date().toISOString()),
  "author": {
    "@type": "Person",
    "name": "Boim Thinker"
  },
  "publisher": {
    "@type": "Organization",
    "name": "boim.thinks()",
    "logo": {
      "@type": "ImageObject",
      "url": "https://boim.web.id/favicon.png"
    }
  },
  "image": imageUrl || "https://boim.web.id/favicon.png",
  "articleBody": parsed?.content ? parsed.content.substring(0, 200) + "..." : data.description || "No content available",
  "keywords": data.tags ? data.tags.split(',').map((tag: string) => tag.trim()) : []
};
---

<Layout title={`${data.title_seo || 'Post'} // boim.thinks()`} schemaData={schemaData}
	og={{
		title: data.title_seo || data.title_short || 'boim.thinks()',
		description: data.description || '',
		image: imageUrl || 'https://boim.web.id/favicon.png',
		url: `https://boim.web.id/blog/${data.slug}`,
	}}
>
  <main class="max-w-4xl mx-auto p-6 py-12">
    
    
    <article>
      <!-- Date and Tags -->
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <time class="text-xs text-gray-400 font-semibold">
          {formattedDate}
        </time>
        {data.tags && (
          <div class="flex flex-wrap gap-2">
            {data.tags.split(',').map((tag: string) => (
              <span class="px-3 py-1 text-xs font-semibold rounded-full bg-blue-900/30 text-blue-300 border border-blue-800/50">
                {tag.trim()}
              </span>
            ))}
          </div>
        )}
      </div>

      <!-- Judul SEO -->
      <h1 class="text-2xl font-bold uppercase mb-6 mt-8">{data.title_seo}</h1>

      <!-- Gambar -->
      {imageUrl && (
        <img src={imageUrl} alt={data.title_short} class="w-full h-auto rounded-xl mb-8 border border-gray-800" onerror="this.src='/no_image.webp'" referrerpolicy="no-referrer" />
      )}

      <!-- Judul Short -->
      <h2 class="text-xl font-bold mb-4 text-white">{data.title_short}</h2>

      <!-- Intro -->
      <p class="text-sm text-gray-400 mb-8">{data.intro}</p>

      <!-- Content with prose styling -->
      <div class="prose-custom" set:html={htmlContent} />

    </article>
  </main>
</Layout>
