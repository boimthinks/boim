---
import Layout from '../../layouts/Layout.astro';
import { getBlogPosts } from '../../lib/api';
import { formatDriveUrl } from '../../lib/utils';
import { marked } from 'marked';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post: any) => {
    try {
      const { data } = matter(post.content);
      return {
        params: { slug: data.slug },
        props: { post },
      };
    } catch (e) {
      console.error("Error generating path:", e);
      return null;
    }
  }).filter(Boolean);
}

const { post } = Astro.props;
let data: any = {};
let htmlContent = "";

try {
  const parsed = matter(post.content);
  data = parsed.data;
  htmlContent = marked.parse(parsed.content);
} catch (e) {
  console.error("Error parsing content:", e);
}

const imageUrl = formatDriveUrl(data.feature_image);

// Format date to 'd MMMM yyyy' (Indonesian)
const d = new Date(data.published_at);
let formattedDate = data.published_at;

if (!isNaN(d.getTime())) {
  formattedDate = new Intl.DateTimeFormat('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(d);
}
---

<Layout title={`${data.title_short || 'Post'} | boim.thinks()`}>
  <main class="max-w-4xl mx-auto p-6 py-12">
    
    
    <article>
      <!-- Date and Tags -->
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <time class="text-sm text-gray-400 font-semibold">
          {formattedDate}
        </time>
        {data.tags && (
          <div class="flex flex-wrap gap-2">
            {data.tags.split(',').map((tag: string) => (
              <span class="px-3 py-1 text-xs font-semibold rounded-full bg-blue-900/30 text-blue-300 border border-blue-800/50">
                {tag.trim()}
              </span>
            ))}
          </div>
        )}
      </div>

      <!-- Judul SEO -->
      <h1 class="text-4xl font-bold mb-6 mt-8">{data.title_seo}</h1>

      <!-- Gambar -->
      {imageUrl && (
        <img src={imageUrl} alt={data.title_short} class="w-full h-auto rounded-xl mb-8 border border-gray-800" />
      )}

      <!-- Judul Short -->
      <h2 class="text-xl font-bold mb-4 text-blue-400">{data.title_short}</h2>

      <!-- Intro -->
      <p class="text-sm text-gray-300 mb-8">{data.intro}</p>

      <!-- Content with prose styling -->
      <div class="prose-custom" set:html={htmlContent} />

    </article>
  </main>
</Layout>
