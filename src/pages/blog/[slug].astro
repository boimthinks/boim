---
import Layout from '../../layouts/Layout.astro';
import { getBlogPosts } from '../../lib/api';
import { formatDriveUrl } from '../../lib/utils';
import { marked } from 'marked';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post: any) => {
    try {
      const { data } = matter(post.content);
      return {
        params: { slug: data.slug },
        props: { post },
      };
    } catch (e) {
      console.error("Error generating path:", e);
      return null;
    }
  }).filter(Boolean);
}

const { post } = Astro.props;
let data: any = {};
let htmlContent = "";

try {
  const parsed = matter(post.content);
  data = parsed.data;
  htmlContent = marked.parse(parsed.content);
} catch (e) {
  console.error("Error parsing content:", e);
}

const imageUrl = formatDriveUrl(data.feature_image);
---

<Layout title={`${data.title_short || 'Post'} | boim.thinks()`}>
  <main class="max-w-3xl mx-auto p-6 py-12">
    <a href="/" class="text-gray-400 hover:text-white mb-8 block">&larr; Back to home</a>
    
    <article>
      <!-- Judul SEO -->
      <h1 class="text-4xl font-bold mb-6">{data.title_seo}</h1>

      <!-- Gambar -->
      {imageUrl && (
        <img src={imageUrl} alt={data.title_short} class="w-full h-auto rounded-xl mb-8 border border-gray-800" />
      )}

      <!-- Judul Short -->
      <h2 class="text-2xl font-semibold mb-4 text-blue-400">{data.title_short}</h2>

      <!-- Intro -->
      <p class="text-lg text-gray-300 mb-8 italic">{data.intro}</p>

      <!-- Content with prose styling -->
      <div class="prose-custom" set:html={htmlContent} />
    </article>
  </main>
</Layout>
