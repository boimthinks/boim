---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getBlogPosts } from '../lib/api';
import matter from 'gray-matter';

const posts = await getBlogPosts();
const processedPosts = posts.map((post: any) => {
  try {
    const { data } = matter(post.content);
    return {
      title: data.title_short,
      description: data.description,
      date: data.published_at,
      slug: data.slug,
      feature_image: data.feature_image,
    };
  } catch (e) {
    console.error("Error parsing frontmatter:", e);
    return null;
  }
}).filter(Boolean).sort((a: any, b: any) => {
  const parseDate = (dateStr: string) => {
    if (!dateStr) return new Date(0);
    const [datePart, timePart] = dateStr.split(' ');
    if (!datePart) return new Date(0);
    const [day, month, year] = datePart.split('/');
    return new Date(`${year || '1970'}-${month || '01'}-${day || '01'}T${timePart || '00:00:00'}`);
  };
  return parseDate(b.date).getTime() - parseDate(a.date).getTime();
});
---

<Layout title="boim.thinks() | Home">
  <section class="px-6 s:px-16 d:px-100 pt-12 s:pt-10 pb-12 s:pb-20">
    <div class="max-w-[90rem] mx-auto">
      <p class="text-content-muted text-sm font-medium mb-4 reveal">Blog</p>
      <h1 class="text-3xl s:text-4xl d:text-5xl font-black leading-[1.1] reveal" style="transition-delay: 0.1s">Recent Posts</h1>
      <p class="text-content-secondary mt-4 max-w-[40rem] text-lg reveal" style="transition-delay: 0.2s">
        Thoughts on coding, tech, and life — written with candor and carpe diem energy.
      </p>
    </div>
  </section>

  <section class="px-6 s:px-16 d:px-100 pb-20 s:pb-32">
    <div class="max-w-[90rem] mx-auto">
      <div class="grid grid-cols-1 s:grid-cols-2 gap-x-15 gap-y-15">
        {processedPosts.map((post: any) => (
          <BlogCard {...post} />
        ))}
      </div>
    </div>
  </section>
</Layout>
